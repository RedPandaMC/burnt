{
  "$schema": "https://opencode.ai/config.json",

  // ── Model & Provider ──────────────────────────────────────────────
  "model": "minimax/minimax-m2.5",

  // ── Instructions (replaces "general_rules") ───────────────────────
  // These are injected into every session as system context.
  // Put your system rules, coding standards, and kanban board state here.
  "instructions": [
    "rules/system_rules.md"
  ],

  // ── Default Agent ─────────────────────────────────────────────────
  "default_agent": "build"
}