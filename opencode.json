{
  "$schema": "https://opencode.ai/schema.json",
  "version": "1.0",
  "general_rules": {
    "enabled": true,
    "rules_file": "rules/system_rules.yaml",
    "injector_module": "rules.injector",
    "bootstrap_function": "get_bootstrap_prompt"
  },
  "kanban_tickets": {
    "enabled": true,
    "module": "tickets.ticket_manager",
    "board_file": "tickets/examples/example_board.xml",
    "schema_file": "tickets/schema/ticket_schema.xsd",
    "columns": ["Backlog", "In Progress", "Review", "Done"]
  },
  "on_new_session": {
    "inject_rules": true,
    "load_board": true
  }
}
